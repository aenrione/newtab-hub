{
  "manifest_version": 3,
  "name": "New Tab Hub",
  "description": "A keyboard-first new tab dashboard with links, RSS feeds, and market tickers.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
